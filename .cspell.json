{
  "language": "en,en-US",
  "version": "0.2",
  "ignorePaths": [
    "**/.cspell.json",
    "**/.gitignore",
    "**/.git/**",
    "**/node_modules/**",
    "**/package-lock.json",
    ".github/workflows/*.yml"
  ],
  "ignoreRegExpList": [
    "/`+([\\s\\S]*?)`+/g",
    "/^```[\\s\\S]*?^```/gm",
    "/\\w*\\_\\w*/g"
  ],
  "words": [
    "withinfocus",
    "dasharray",
    "exfiltration",
    "favicons",
    "gatech",
    "imobile",
    "Inkscape",
    "linecap",
    "linejoin",
    "Logomark",
    "msapplication",
    "mstile",
    "noopener",
    "OHMER",
    "rarr",
    "SDLC",
    "Statiq",
    "stylesheet",
    "throughline",
    "TSYS",
    "nums",
    "schooler",
    "XNYTNNK"
  ]
}
